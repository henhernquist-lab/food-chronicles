# ──────────────────────────────────────────────────────────────────────────────
# Food Chronicle — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic Claude — used for AI Sommelier, Article Expansion, and auto-moderation
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs — used for Audio Article Mode (TTS generation)
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Pexels — used for Cinematic Hero video fetching (server-side only)
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Resend — used for Weekly Digest emails and submission notifications
VITE_RESEND_API_KEY=your_resend_api_key_here

# Supabase — used for persisting conversations, submissions, votes, and audio
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
